<div class="row">
  <div class="col-sm-12">

    {# Title: linked to PDF if pdf field exists, otherwise plain #}
    {% if entry.pdf %}
      {% if entry.pdf contains '://' %}
        {% assign pdf_url = entry.pdf %}
      {% else %}
        {% assign pdf_url = entry.pdf | prepend: '/assets/pdf/' | relative_url %}
      {% endif %}
      <h4 class="title">
        <a href="{{ pdf_url }}" target="_blank" rel="noopener">{{ entry.title }}</a>
      </h4>
    {% else %}
      <h4 class="title">{{ entry.title }}</h4>
    {% endif %}

    {# Coauthors: only show if there's more than one author #}
    {% if entry.author_array.size > 1 %}
      <div class="coauthors">
        with
        {% for author in entry.author_array %}
          {% assign author_full = author.first | append: ' ' | append: author.last %}
          {% comment %}Skip yourself in the coauthor list{% endcomment %}
          {% unless author.last == 'Hoffman' %}
            {{ author_full }}{% unless forloop.last %}, {% endunless %}
          {% endunless %}
        {% endfor %}
      </div>
    {% endif %}

    {# Note (e.g., "Job Market Paper") #}
    {% if entry.note %}
      <div class="note"><em>{{ entry.note }}</em></div>
    {% endif %}

    {# Presentations list #}
    {% if entry.presentations %}
      <div class="presentations">
        <strong>Presentations:</strong>
        <ul>
          {% assign presentation_list = entry.presentations | split: ';' %}
          {% for p in presentation_list %}
            <li>{{ p | strip }}</li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    {# Collapsable abstract #}
    {% if entry.abstract %}
      <div class="abstract-toggle">
        <button class="btn-abstract" onclick="
          var box = this.nextElementSibling;
          box.style.display = box.style.display === 'block' ? 'none' : 'block';
          this.textContent = box.style.display === 'block' ? 'Hide abstract' : 'Show abstract';
        ">Show abstract</button>
        <div class="abstract-box" style="display: none;">
          {{ entry.abstract }}
        </div>
      </div>
    {% endif %}

  </div>
</div>