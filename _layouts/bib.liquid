<div class="row">
  <div class="col-sm-12">

    {% comment %} {# Title: linked to PDF if pdf field exists, otherwise plain #} {% endcomment %}
    <h4 class="title">{{ entry.title }}</h4>

    {% comment %} {# Coauthors: only show if there's more than one author #} {% endcomment %}
    {% if entry.author_array.size > 1 %}
      <div class="coauthors">
        with
        {% for author in entry.author_array %}
          {% assign author_full = author.first | append: ' ' | append: author.last %}
          {% comment %}Skip yourself in the coauthor list{% endcomment %}
          {% unless author.last == 'Hoffman' %}
            {{ author_full }}{% unless forloop.last %}, {% endunless %}
          {% endunless %}
        {% endfor %}
      </div>
    {% endif %}

    {% if entry.pdf or entry.slides or entry.published or entry.code or entry.nber %}
      <div class="paper-links">
        {% if entry.pdf %}
          {% if entry.pdf contains '://' %}
            {% assign pdf_url = entry.pdf %}
          {% else %}
            {% assign pdf_url = entry.pdf | prepend: '/assets/pdf/' | relative_url %}
          {% endif %}
          {% comment %} <a class="btn-link" href="{{ pdf_url }}" target="_blank" rel="noopener">Working Paper</a> {% endcomment %}
          <a class="btn-link" href="{{ pdf_url }}" target="_blank" rel="noopener">PDF</a>
        {% endif %}

        {% if entry.slides %}
          {% if entry.slides contains '://' %}
            {% assign slides_url = entry.slides %}
          {% else %}
            {% assign slides_url = entry.slides | prepend: '/assets/pdf/' | relative_url %}
          {% endif %}
          <a class="btn-link" href="{{ slides_url }}" target="_blank" rel="noopener">Slides</a>
        {% endif %}

        {% if entry.published %}
          <a class="btn-link" href="{{ entry.published }}" target="_blank" rel="noopener">Published Version</a>
        {% endif %}

        {% if entry.nber %}
          <a class="btn-link" href="{{ entry.nber }}" target="_blank" rel="noopener">NBER</a>
        {% endif %}

        {% if entry.code %}
          <a class="btn-link" href="{{ entry.code }}" target="_blank" rel="noopener">Code</a>
        {% endif %}
      </div>
    {% endif %}

    {% comment %} {# Note (e.g., "Job Market Paper") #} {% endcomment %}
    {% if entry.note %}
      <div class="note"><em>{{ entry.note }}</em></div>
    {% endif %}

    {% comment %} {# Presentations list #} {% endcomment %}
    {% if entry.presentations %}
      <div class="presentations">
        <strong>Presentations:</strong>
        <ul>
          {% assign presentation_list = entry.presentations | split: ';' %}
          {% for p in presentation_list %}
            <li>{{ p | strip }}</li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    {% comment %} {# Collapsable abstract #} {% endcomment %}
    {% if entry.abstract %}
      <div class="abstract-toggle">
        <button class="btn-abstract" onclick="
          var box = this.nextElementSibling;
          box.style.display = box.style.display === 'block' ? 'none' : 'block';
          this.textContent = box.style.display === 'block' ? 'Hide abstract' : 'Show abstract';
        ">Show abstract</button>
        <div class="abstract-box" style="display: none;">
          {{ entry.abstract }}
        </div>
      </div>
    {% endif %}

  </div>
</div>